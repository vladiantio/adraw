---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { class: className, ...props } = Astro.props;
---

<div class:list={["relative", className]} {...props}>
  <div class="toolbar flex items-center gap-1 p-1 w-fit absolute top-2 left-1/2 -translate-x-1/2 bg-card rounded-lg shadow-lg shadow-black/5 border">
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border bg-primary/20 text-primary size-10 inline-flex items-center justify-center" data-tool="select" title="Select (V)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mouse-pointer-icon lucide-mouse-pointer"><path d="M12.586 12.586 19 19"/><path d="M3.688 3.037a.497.497 0 0 0-.651.651l6.5 15.999a.501.501 0 0 0 .947-.062l1.569-6.083a2 2 0 0 1 1.448-1.479l6.124-1.579a.5.5 0 0 0 .063-.947z"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="hand" title="Hand (H)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-hand-icon lucide-hand"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="rectangle" title="Rectangle (R)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-icon lucide-square"><rect width="18" height="18" x="3" y="3" rx="2"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="ellipse" title="Ellipse (E)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-icon lucide-circle"><circle cx="12" cy="12" r="10"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="draw" title="Draw (D)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pencil-icon lucide-pencil"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="line" title="Line (L)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-minus-icon lucide-minus"><path d="M5 12h14"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-tool="eraser" title="Eraser (E)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eraser-icon lucide-eraser"><path d="M21 21H8a2 2 0 0 1-1.42-.587l-3.994-3.999a2 2 0 0 1 0-2.828l10-10a2 2 0 0 1 2.829 0l5.999 6a2 2 0 0 1 0 2.828L12.834 21"/><path d="m5.082 11.09 8.828 8.828"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="insert-media" title="Insert image">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image-icon lucide-image"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
    </button>
    <div class="separator w-px h-6 bg-border"></div>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="undo" title="Undo (Ctrl+Z)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-undo-icon lucide-undo"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="redo" title="Redo (Ctrl+Shift+Z)">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-redo-icon lucide-redo"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"/></svg>
    </button>
    <div class="separator w-px h-6 bg-border"></div>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="zoom-in" title="Zoom In">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus-icon lucide-plus"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border h-10 w-16 inline-flex items-center justify-center tabular-nums" data-action="reset" title="Reset">100%</button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="zoom-out" title="Zoom Out">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-minus-icon lucide-minus"><path d="M5 12h14"/></svg>
    </button>
    <button class="border border-transparent rounded-md hover:bg-primary/10 active:border-border size-10 inline-flex items-center justify-center" data-action="zoom-fit" title="Zoom to Fit">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ratio-icon lucide-ratio"><rect width="12" height="20" x="6" y="2" rx="2"/><rect width="20" height="12" x="2" y="6" rx="2"/></svg>
    </button>
    <input id="file-input" type="file" accept="image/*" hidden multiple />
  </div>
  <div class="canvas-container size-full"></div>
</div>

<script>
  import { AdrawCanvas, type MediaInput, type ToolType } from '@adraw/core'

  const toolbar = document.querySelector<HTMLDivElement>(".toolbar")!

  const canvasContainer = document.querySelector<HTMLDivElement>(".canvas-container")!

  const canvas = new AdrawCanvas({
    container: canvasContainer,
  })

  canvas.on("viewportChange", (ev) => {
    document.querySelector<HTMLButtonElement>(`[data-action="reset"]`)!.textContent = `${Math.floor(ev.viewport.zoom * 100)}%`
  })

  canvas.on("toolChange", (ev) => {
    updateToolbar()
  })

  const buttons = toolbar.querySelectorAll<HTMLButtonElement>("[data-tool]")
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tool = btn.dataset.tool as ToolType
      canvas.setActiveTool(tool)
      updateToolbar()
    })
  })

  // Media insertion
  const fileInput = document.getElementById("file-input") as HTMLInputElement

  fileInput.addEventListener("change", async () => {
    const files = fileInput.files
    if (!files || files.length === 0) {
      return
    }

    const descriptors: MediaInput[] = await Promise.all(
      Array.from(files, async (file) => {
        const dataUrl = await readFileAsDataURL(file)
        const img = await getImageFromSrc(dataUrl)
        return {
          mimeType: file.type,
          naturalHeight: img.naturalHeight,
          naturalWidth: img.naturalWidth,
          src: dataUrl,
        }
      }),
    )

    if (descriptors.length > 0) {
      canvas.insertMedia(descriptors)
    }

    fileInput.value = ""
  })

  const readFileAsDataURL = (file: File | Blob) =>
    new Promise<string>((resolve, reject) => {
      const reader = new FileReader()
      reader.readAsDataURL(file)
      reader.addEventListener("load", (ev) => {
        if (ev.target?.readyState === FileReader.DONE) {
          resolve(ev.target.result as string)
        } else {
          reject(new Error("Failed to load file."))
        }
      })
      reader.addEventListener("error", reject)
    })

  const getImageFromSrc = (src: string) =>
    new Promise<HTMLImageElement>((resolve, reject) => {
      const img = new Image()
      img.onload = () => resolve(img)
      img.onerror = reject
      img.src = src
    })

  const actionButtons =
    toolbar.querySelectorAll<HTMLButtonElement>("[data-action]")
  actionButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const {action} = btn.dataset
      switch (action) {
        case "insert-media": {
          fileInput.click()
          break
        }
        case "undo": {
          canvas.undo()
          break
        }
        case "redo": {
          canvas.redo()
          break
        }
        case "zoom-in": {
          canvas.zoomIn()
          break
        }
        case "zoom-out": {
          canvas.zoomOut()
          break
        }
        case "zoom-fit": {
          canvas.zoomToFit()
          break
        }
        case "reset": {
          canvas.resetZoom()
          break
        }
      }
    })
  })

  function updateToolbar() {
    const activeTool = canvas.getActiveTool()
    buttons.forEach((btn) => {
      "active bg-primary/20 hover:bg-primary/20 text-primary".split(" ").forEach(c => btn.classList.toggle(c, btn.dataset.tool === activeTool))
      btn.ariaPressed = btn.dataset.tool === activeTool ? "true" : null
    })
  }

  updateToolbar()
</script>
